      },
      "source_file": "Layer3 모답스 동작 분석 자료",
      "source_sheet": "대기시간",
      "source_range": "",
      "status": "RULE_NOT_CONFIRMED",
      "verified_by": "",
      "remarks": "작동대기(1 Cycle/2 Cycle) 구조 확인 - cycle_time 미확정"
    },
    {
